{
  "name": "cit-coin",
  "version": "1.0.0",
  "main": "index.js",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@ethersproject/abi": "^5.7.0",
    "@ethersproject/providers": "^5.7.2",
    "@nomicfoundation/hardhat-chai-matchers": "^1.0.6",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.8",
    "@nomicfoundation/hardhat-toolbox": "^2.0.2",
    "@nomicfoundation/hardhat-verify": "^2.0.8",
    "@nomiclabs/hardhat-ethers": "^2.2.2",
    "@nomiclabs/hardhat-etherscan": "^3.1.7",
    "@nomiclabs/hardhat-waffle": "^2.0.5",
    "@openzeppelin/contracts": "^4.8.2",
    "@typechain/ethers-v5": "^10.2.0",
    "@typechain/hardhat": "^6.1.5",
    "@types/chai": "^4.3.4",
    "@types/mocha": "^10.0.1",
    "@types/node": "^18.14.6",
    "chai": "^4.3.7",
    "dotenv": "^16.0.3",
    "ethers": "^5.7.2",
    "hardhat": "^2.22.6",
    "hardhat-gas-reporter": "^1.0.9",
    "prettier-plugin-solidity": "^1.1.3",
    "solhint": "^3.4.1",
    "solidity-coverage": "^0.8.2",
    "ts-node": "^10.9.1",
    "typechain": "^8.1.1",
    "typescript": "^4.9.5"
  },
  "scripts": {
    "start": "npx hardhat node",
    "test": "npx hardhat test --grep LearnToEarn",
    "test:join": "npx hardhat test --grep JOIN",
    "test:ichigo": "npx hardhat test --grep ICHIGO",
    "test:faucet": "npx hardhat test --grep Faucet",
    "test:nft": "npx hardhat test --grep NFT",
    "test:all": "npx hardhat test",
    "compile": "npx hardhat compile",
    "flatten:cjpy": "npx hardhat flatten contracts/cJPY.sol > contracts/cJPY.flat.sol",
    "flatten:learntoearn": "npx hardhat flatten contracts/LearnToEarn.sol > contracts/LearnToEarn.flat.sol",
    "flatten:nft": "npx hardhat flatten contracts/CitNFT.sol > contracts/CitNFT.flat.sol",
    "flatten:join": "npx hardhat flatten contracts/JOIN.sol > contracts/JOIN.flat.sol",
    "flatten:ichigo": "npx hardhat flatten contracts/ICHIGO.sol > contracts/ICHIGO.flat.sol",
    "flatten": "yarn flatten:cjpy && yarn flatten:learntoearn && yarn flatten:nft && yarn flatten:join && yarn flatten:ichigo",
    "deploy:mainnet": "npx hardhat run scripts/deploy.ts --network optimism",
    "deploy:testnet": "npx hardhat run scripts/deploy.ts --network optimismSepolia",
    "deploy:mainnet:learn": "npx hardhat run scripts/deployLearnToEarn.ts --network optimism",
    "deploy:testnet:learn": "npx hardhat run scripts/deployLearnToEarn.ts --network optimismSepolia",
    "mint:testnet:cjpy": "npx hardhat run scripts/mintCJPY.ts --network optimismSepolia",
    "mint:testnet:join": "npx hardhat run scripts/mintJOIN.ts --network optimismSepolia",
    "mint:mainnet:join": "npx hardhat run scripts/mintJOIN.ts --network optimism",
    "mint:testnet:ichigo": "npx hardhat run scripts/mintICHIGO.ts --network optimismSepolia",
    "mint:mainnet:ichigo": "npx hardhat run scripts/mintICHIGO.ts --network optimism",
    "verify:join-test": "npx hardhat verify --network optimismSepolia --contract contracts/JOIN.sol:JOIN",
    "verify:join": "npx hardhat verify --network optimism --contract contracts/JOIN.sol:JOIN",
    "verify:ichigo-test": "npx hardhat verify --network optimismSepolia --contract contracts/ICHIGO.sol:ICHIGO",
    "verify:ichigo": "npx hardhat verify --network optimism --contract contracts/ICHIGO.sol:ICHIGO",
    "verify:cjpy-test": "npx hardhat verify --network optimismSepolia --contract contracts/cJPY.sol:CJPY",
    "verify:faucet-test": "npx hardhat verify --network optimismSepolia --contract contracts/Faucet.sol:Faucet",
    "verify:learn-test": "npx hardhat verify --network optimismSepolia --contract contracts/LearnToEarn.sol:LearnToEarn",
    "verify:nft-test": "npx hardhat verify --network optimismSepolia --contract contracts/CitNFT.sol:CitNFT",
    "verify:registry-test": "npx hardhat verify --network optimismSepolia --contract contracts/Registry.sol:Registry",
    "verify:cjpy": "npx hardhat verify --network optimism --contract contracts/cJPY.sol:CJPY",
    "verify:faucet": "npx hardhat verify --network optimism --contract contracts/Faucet.sol:Faucet",
    "verify:learn": "npx hardhat verify --network optimism --contract contracts/LearnToEarn.sol:LearnToEarn",
    "verify:nft": "npx hardhat verify --network optimism --contract contracts/CitNFT.sol:CitNFT",
    "verify:registry": "npx hardhat verify --network optimism --contract contracts/Registry.sol:Registry",
    "format:sol": "yarn solhint --fix --max-warnings 5 \"contracts/**/*.sol\" && prettier --write './contracts/**/*.sol'",
    "format:js": "prettier --write './{test,script,contracts}/**/*.{ts,js}'",
    "format": "yarn format:sol && yarn format:js"
  }
}
